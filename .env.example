# 환경 변수 템플릿 — 값을 채운 뒤 .env로 복사(cp .env.example .env). .env는 커밋 금지.
# 연동 시크릿(카카오/Solapi, SMTP, Dropbox, 네이버웍스)은 여기가 아니라
# 애플리케이션 설정(연동) 화면에서 관리한다. SECURITY.md 참고.

# 데이터베이스
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hooxi_cms
DB_USER=hooxi
DB_PASSWORD=change_me_in_production   # 12자 이상 강한 값

# 인증
JWT_SECRET=change_me_to_a_strong_random_value
ALLOWED_EMAIL_DOMAIN=hooxipartners.com
ENABLE_DEV_LOGIN=false                # 운영에서는 비활성
SEED_ADMIN_EMAIL=

# CORS / URL
CORS_ORIGINS=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:8000

# 배치
BATCH_SECRET=change_me

# 파일 스토리지 (선택 — 미설정 시 로컬 UPLOAD_DIR 사용)
UPLOAD_DIR=./uploads
GCS_BUCKET=

# Cloud SQL 백업 (선택 — 미설정 시 백업 기능 비활성)
GCP_PROJECT=
CLOUDSQL_INSTANCE=

# 서버
PORT=8000
